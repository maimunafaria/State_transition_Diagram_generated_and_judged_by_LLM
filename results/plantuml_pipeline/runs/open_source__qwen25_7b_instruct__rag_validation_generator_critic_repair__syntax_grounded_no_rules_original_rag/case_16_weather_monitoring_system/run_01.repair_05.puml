@startuml
[*] --> Register

state Register {
  Register --> Login : registration successful
  Register --> Register : registration unsuccessful
}

state Login {
  Login --> CheckLocation : login successful
  Login --> Login : login unsuccessful
}

state CheckLocation {
  CheckLocation --> CheckInfo : location valid
  CheckLocation --> CheckLocation : invalid location
}

state CheckInfo {
  CheckInfo --> ChooseInfo : selection valid
  CheckInfo --> CheckInfo : invalid selection
}

state ChooseInfo {
  ChooseInfo --> ShowInfo : valid selection
  ChooseInfo --> ChooseInfo : invalid selection
}

state ShowInfo {
  ShowInfo --> ViewDetails : view additional details
  ShowInfo --> ShowInfo : logout
}

state ViewDetails {
  ViewDetails --> Logout : additional details viewed
}

state Logout {
  Logout --> END : session ended
}

state END {}

@enduml
