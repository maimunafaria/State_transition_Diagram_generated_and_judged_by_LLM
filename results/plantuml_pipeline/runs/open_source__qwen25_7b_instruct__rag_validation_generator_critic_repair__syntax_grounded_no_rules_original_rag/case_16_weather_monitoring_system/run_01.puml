@startuml
[*] --> Register

state Register {
  [*] --> Login : registration successful
  Login --> [*] : registration unsuccessful
}

state Login {
  [*] --> CheckLocation : login successful
  CheckLocation --> [*] : invalid location
}

state CheckLocation {
  [*] --> CheckInfo : location valid
  CheckInfo --> [*] : location invalid
}

state CheckInfo {
  [*] --> ChooseInfo : selection valid
  ChooseInfo --> [*] : invalid selection
}

state ChooseInfo {
  [*] --> ShowInfo : valid selection
  ShowInfo --> [*] : logout
}

state ShowInfo {
  [*] --> ViewDetails : view additional details
}

state ViewDetails {
  [*] --> Logout : additional details viewed
}

state Logout {
  [*] --> END : session ended
}

@enduml
