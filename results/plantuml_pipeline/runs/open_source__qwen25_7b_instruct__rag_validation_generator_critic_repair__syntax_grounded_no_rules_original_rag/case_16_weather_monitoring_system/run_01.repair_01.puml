@startuml
[*] --> Register

state Register {
  Login <|-- Register : registration successful
  Register --> Login : registration unsuccessful
}

state Login {
  CheckLocation <|-- Login : login successful
  Login --> [*] : registration unsuccessful
}

state CheckLocation {
  CheckInfo <|-- CheckLocation : location valid
  CheckLocation --> [*] : invalid location
}

state CheckInfo {
  ChooseInfo <|-- CheckInfo : location valid
  CheckInfo --> [*] : invalid selection
}

state ChooseInfo {
  ShowInfo <|-- ChooseInfo : valid selection
  ChooseInfo --> [*] : logout
}

state ShowInfo {
  ViewDetails <|-- ShowInfo : view additional details
  ShowInfo --> [*] : logout
}

state ViewDetails {
  [*] --> [*] : additional details viewed
  ViewDetails --> [*] : logout
}

@enduml
