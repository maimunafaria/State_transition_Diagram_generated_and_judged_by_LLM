@startuml
[*] --> Off

state Off {
  Off --> Idle : turn off
}

state Idle {
  Idle --> SetAlarm : set alarm
  SetAlarm --> AlarmSet : alarm set
}

state AlarmSet {
  AlarmSet --> Ringing : alarm time reached
  Ringing --> Ringing : keep ringing
  Ringing --> Stopped : stop alarm
  Stopped --> Idle : alarm stopped
}

Ringing --> Ringing : keep ringing
Stopped --> Idle : alarm stopped

AlarmSet --> Off : turn off
Off --> [*] : completion
@enduml
