@startuml

[*] --> AddNewGoods

state "Add New Goods" as AddNewGoods
state "Update Price" as UpdatePrice
state "Remove Goods" as RemoveGoods
state "Identify Expired Goods" as IdentifyExpiredGoods
state "Place Order" as PlaceOrder
state "Generate Invoice" as GenerateInvoice
state "Search Items" as SearchItems
state "Calculate Discount and Tax" as CalculateDiscountTax
state "Generate Receipt" as GenerateReceipt
state "Replace Item or Cancel Receipt" as ReplaceItemCancelReceipt
state "Record Customer Requests" as RecordCustomerRequests
state "View Summary Report" as ViewSummaryReport

AddNewGoods --> UpdatePrice
UpdatePrice --> RemoveGoods
RemoveGoods --> IdentifyExpiredGoods
IdentifyExpiredGoods --> PlaceOrder
PlaceOrder --> GenerateInvoice
GenerateInvoice --> SearchItems
SearchItems --> CalculateDiscountTax
CalculateDiscountTax --> GenerateReceipt
GenerateReceipt --> ReplaceItemCancelReceipt
ReplaceItemCancelReceipt --> RecordCustomerRequests
RecordCustomerRequests --> ViewSummaryReport

ViewSummaryReport --> [*] : COMPLETION_EVENT

AddNewGoods --> AddNewGoods : REACH_ADD_NEW_GOODS
UpdatePrice --> UpdatePrice : RECALCULATE_PRICE
RemoveGoods --> RemoveGoods : REMOVE_GOODS
IdentifyExpiredGoods --> IdentifyExpiredGoods : CHECK_EXPIRATION
PlaceOrder --> PlaceOrder : ORDER_SUPPLIER
GenerateInvoice --> GenerateInvoice : ISSUE_INVOICE
SearchItems --> SearchItems : SEARCH_ITEMS
CalculateDiscountTax --> CalculateDiscountTax : APPLY_DISCOUNT_TAX
GenerateReceipt --> GenerateReceipt : PRINT_RECEIPT
ReplaceItemCancelReceipt --> ReplaceItemCancelReceipt : REPLACE_OR_CANCEL
RecordCustomerRequests --> RecordCustomerRequests : RECORD_REQUESTS

@enduml
