@startuml

[*] --> AddNewGoods

state "Add New Goods" as AddNewGoods
state "Update Price" as UpdatePrice
state "Remove Goods" as RemoveGoods
state "Identify Expired Goods" as IdentifyExpiredGoods
state "Place Order" as PlaceOrder
state "Generate Invoice" as GenerateInvoice
state "Search Items" as SearchItems
state "Calculate Discount and Tax" as CalculateDiscountTax
state "Generate Receipt" as GenerateReceipt
state "Replace Item or Cancel Receipt" as ReplaceItemCancelReceipt
state "Record Customer Requests" as RecordCustomerRequests
state "View Summary Report" as ViewSummaryReport

AddNewGoods --> UpdatePrice : ADD_NEW_GOODS
UpdatePrice --> RemoveGoods : UPDATE_PRICE
RemoveGoods --> IdentifyExpiredGoods : REMOVE_GOODS
IdentifyExpiredGoods --> PlaceOrder : IDENTIFY_EXPIRED_GOODS
PlaceOrder --> GenerateInvoice : PLACE_ORDER
GenerateInvoice --> SearchItems : GENERATE_INVOICE
SearchItems --> CalculateDiscountTax : SEARCH_ITEMS
CalculateDiscountTax --> GenerateReceipt : CALCULATE_DISCOUNT_TAX
GenerateReceipt --> ReplaceItemCancelReceipt : GENERATE_RECEIPT
ReplaceItemCancelReceipt --> RecordCustomerRequests : REPLACE_ITEM_OR_CANCEL_RECEIPT
RecordCustomerRequests --> ViewSummaryReport : RECORD_CUSTOMER_REQUESTS

ViewSummaryReport --> [*] : COMPLETION_EVENT

@enduml
