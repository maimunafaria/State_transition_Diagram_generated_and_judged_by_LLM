@startuml
title UML State Chart Diagram for E Ticketing For Bus

[*] --> Registration

state Registration {
    EnterDetails
    ValidateDetails
    RegistrationComplete
    ReEnterDetails

    [*] --> EnterDetails : [New Account]
    EnterDetails --> ValidateDetails : [Valid]
    EnterDetails --> ReEnterDetails : [Invalid]
    ReEnterDetails --> EnterDetails : [Re-enter Details]
    ValidateDetails --> RegistrationComplete : [Validation Complete]
}

RegistrationComplete --> Login

state Login {
    Authenticate
    LoginSuccess
    LoginFailed

    [*] --> Authenticate : [Login]
    Authenticate --> LoginSuccess : [Valid]
    Authenticate --> LoginFailed : [Invalid]
}

LoginSuccess --> Dashboard

state Dashboard {
    CheckTicketStatus
    BookTicket
    ConfirmBooking
    MakePayment
    PaymentSuccess
    ManageAccount
    Logout
    EditDetails
    DeleteAccount

    [*] --> CheckTicketStatus : [Check Status]
    CheckTicketStatus --> Dashboard : [Back to Dashboard]
    [*] --> BookTicket : [Book Ticket]
    BookTicket --> ConfirmBooking : [Confirm Booking]
    ConfirmBooking --> MakePayment : [Make Payment]
    MakePayment --> PaymentSuccess : [Payment Success]
    PaymentSuccess --> Dashboard : [Back to Dashboard]
    [*] --> ManageAccount : [Manage Account]
    ManageAccount --> Dashboard : [Back to Dashboard]
    [*] --> Logout : [Logout]
    Logout --> [*] : [Logged Out]
}

state ManageAccount {
    EditDetails
    DeleteAccount

    [*] --> EditDetails : [Edit Details]
    EditDetails --> Dashboard : [Back to Dashboard]
    [*] --> DeleteAccount : [Delete Account]
    DeleteAccount --> [*] : [Deleted Account]
}

CheckTicketStatus --> Dashboard

@enduml
