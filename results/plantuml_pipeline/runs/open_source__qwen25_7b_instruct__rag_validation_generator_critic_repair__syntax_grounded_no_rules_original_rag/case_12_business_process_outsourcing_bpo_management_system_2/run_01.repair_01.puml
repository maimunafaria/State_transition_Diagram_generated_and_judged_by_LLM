@startuml
title UML State Machine Diagram - BPO Management System

[*] --> SearchCriteria

state "SearchCriteria" as SearchCriteria {
    SearchCriteria --> FilterCategory : [Select category]
    SearchCriteria --> PriceRange : [Select price range]
}

state "FilterCategory" as FilterCategory
FilterCategory --> DisplayResults : [Criteria met]

state "PriceRange" as PriceRange
PriceRange --> DisplayResults : [Criteria met]

state "DisplayResults" as DisplayResults
DisplayResults --> [*] : [Matching users displayed]

@enduml
