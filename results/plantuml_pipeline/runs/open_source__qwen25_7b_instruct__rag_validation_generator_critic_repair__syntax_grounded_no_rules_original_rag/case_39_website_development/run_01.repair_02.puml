@startuml
title UML State Machine Diagram

[*] --> NavigationBar

state HomePage {
  HomePage --> Projects : SelectProjects
  HomePage --> CareerOpportunities : ViewCareerOpportunities
}

state Projects {
  Projects --> ViewPhotos : ViewPhotos
  Projects --> ViewVideos : ViewVideos
  ViewPhotos --> Projects : BackToProjects
  ViewVideos --> Projects : BackToProjects
}

state CareerOpportunities {
  CareerOpportunities --> ViewUpdates : ViewUpdates
  CareerOpportunities --> ApplicationForm : ApplyForJob
  ViewUpdates --> CareerOpportunities : BackToCareerOpportunities
  ApplicationForm --> CareerOpportunities : SubmitApplication
}

state CareerOpportunitiesReview {
  CareerOpportunities --> CareerOpportunitiesReview : CheckApplications
  CareerOpportunitiesReview --> [*] : Submit
}

@enduml
