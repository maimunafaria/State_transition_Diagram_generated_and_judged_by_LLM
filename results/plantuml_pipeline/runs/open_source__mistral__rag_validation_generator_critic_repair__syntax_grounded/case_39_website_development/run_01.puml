@startuml
state Homepage
Homepage --> NavigationBar

NavigationBar --> Projects
Projects : displayInfo
Projects : photosVideosChoice

[*] --> Homepage : enter

Projects --> CareerOpportunities
CareerOpportunities : updateApplicationFormChoice

state Photos
Photos : viewPhotos
Homepage --> Photos : navigateToPhotos

state Videos
Videos : viewVideos
Homepage --> Videos : navigateToVideos

Projects --> Projects : backToProjects
CareerOpportunities --> CareerOpportunities : backToCareerOpportunities

CareerOpportunities --> JobApplications
JobApplications : submitApplication
JobApplications : checkSubmittedApplications

state Updates
Updates : viewUpdates
CareerOpportunities --> Updates : navigateToUpdates

state ApplicationForm
ApplicationForm : openForm
JobApplications --> ApplicationForm : navigateToApplicationForm

Projects --> Projects : backToHomepage
CareerOpportunities --> CareerOpportunities : backToHomepage
Updates --> Updates : backToCareerOpportunities
ApplicationForm --> JobApplications : submitApplicationBack
JobApplications --> Homepage : backToHomepage

Projects --> TerminalState : exitProjects
CareerOpportunities --> TerminalState : exitCareerOpportunities
Updates --> TerminalState : exitUpdates
ApplicationForm --> TerminalState : exitApplicationForm
TerminalState --> [*] : COMPLETION_EVENT
@enduml
