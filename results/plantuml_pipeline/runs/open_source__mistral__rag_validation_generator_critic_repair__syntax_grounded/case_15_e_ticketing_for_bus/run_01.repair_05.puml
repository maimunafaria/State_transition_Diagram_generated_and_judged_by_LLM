@startuml
[*] --> LoggedIn

state LoggedIn {
  INITIAL_STATE --> Dashboard
  Dashboard --> Settings : open settings
  Settings --> Dashboard : back
  Dashboard --> BookTicket : book ticket
  BookTicket --> PaymentConfirmation : payment confirmed
  PaymentConfirmation --> OrderCompleted : order completed
  OrderCompleted --> LoggedIn : logout
}

LoggedIn --> [*] : logout
@enduml
