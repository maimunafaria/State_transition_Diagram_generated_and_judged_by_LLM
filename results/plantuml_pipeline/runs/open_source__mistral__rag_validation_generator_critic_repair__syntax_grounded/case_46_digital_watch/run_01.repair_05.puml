@startuml
Digital Watch State Machine Diagram

[*] --> Idle
Idle --> ChangeTime
ChangeTime --> HourAdjust
HourAdjust --> MinuteAdjust
MinuteAdjust --> AlarmHourAdjust
AlarmHourAdjust --> AlarmMinuteAdjust
AlarmMinuteAdjust --> LightOnOff
LightOnOff --> Idle : LightOff_Event

[*] --> AlarmOn
AlarmOn --> AlarmRinging
AlarmRinging --> AlarmStopped
AlarmStopped --> Idle : AlarmStopped_Event

state TerminalState
TerminalState --> [*] : COMPLETION_EVENT

state LightOn
LightOn --> LightOff
LightOff --> Idle
Idle --> LightOn : LightOn_Event
@enduml
