@startuml
title Healthcare Portal - User State Machine Diagram

state RegistrationChoice1 <<choice>>
state RegistrationChoice2 <<choice>>
state LoginChoice <<choice>>
state HomePage <<choice>>
state NewsContent <<choice>>
state HealthCheckup <<choice>>
state PaymentMethodSelection <<choice>>
state CashPaymentDetails <<choice>>
state InsurancePaymentCompletion <<choice>>
state FeedbackCollection <<choice>>
state Logout <<choice>>
state RegistrationFailure <<choice>>

[*] --> RegistrationChoice1

RegistrationChoice1 --> RegistrationSuccess : [User registered successfully]
RegistrationChoice1 --> RegistrationFailure : [Registration failed]

RegistrationFailure --> LoginChoice : [Try again or exit]

LoginChoice --> LoginSuccess : [Valid credentials entered]
LoginChoice --> LoginFailed : [Invalid credentials entered]

LoginFailed --> RegistrationChoice2 : [Return to registration]
LoginSuccess --> HomePage : [Display home page]

HomePage --> NewsContent : [View news and expert content]
HomePage --> HealthCheckup : [Health-related information]
HomePage --> PaymentMethodSelection : [Select payment method]

PaymentMethodSelection --> CashPayment : [Cash payment selected]
PaymentMethodSelection --> InsurancePayment : [Insurance payment selected]

CashPayment --> CashPaymentDetails : [Display cash payment details]
CashPaymentDetails --> PaymentCompleted : [Complete cash payment process]

InsurancePayment --> InsurancePaymentCompletion : [Complete insurance-based payment process]

HealthCheckup --> CheckResult : [View result]
CheckResult --> ContinueSession : [Continue using the system or finish session]

NewsContent --> ContinueSession : [Continue using the system or finish session]

FeedbackCollection --> FeedbackSubmitted : [User feedback collected]

Logout --> LoggedOut : [Log out user at the end of their session]

RegistrationSuccess --> ServiceVerification : [Verify user account]
ServiceVerification --> LoginChoice : [Login if verified, or wait for verification]

@enduml
