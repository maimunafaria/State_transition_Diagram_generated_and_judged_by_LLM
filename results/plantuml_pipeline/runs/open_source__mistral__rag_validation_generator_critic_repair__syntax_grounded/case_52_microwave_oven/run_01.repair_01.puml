@startuml
title Microwave Oven State Machine Diagram

state Idle
[*] --> Idle : powerOn()
Idle --> TimeDisplay

state TimeDisplay
TimeDisplay --> PowerLevelSelection

state PowerLevelSelection
PowerLevelSelection --> CookingTimeInput

state CookingTimeInput
CookingTimeInput --> DoorOpen
DoorOpen --> Inactive : doorClosed()
DoorOpen --> Stop : doorOpenedDuringCooking()

state Inactive
Inactive --> Idle : powerOn()

state Stop
Stop --> Idle : cancelOrStop()

state Cancel
[*] --> Cancel : cancelButtonClicked()
Cancel --> Idle : powerOn()
@enduml
