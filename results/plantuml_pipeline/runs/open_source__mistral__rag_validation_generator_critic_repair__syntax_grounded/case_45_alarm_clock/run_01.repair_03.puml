@startuml
title Alarm Clock State Diagram

state Off {
  [*] --> Off
}

state SetAlarmTime {
  Off --> SetAlarmTime
}

state ActiveAlarm {
  state Ringing {
    SetAlarmTime --> Ringing : current time matches set alarm time
    Ringing --> StoppedByUser : user stops alarm
    Ringing --> NextScheduledAlarm : time passes
  }

  state Stopped {
    [*] --> Stopped
    Stopped --> ActiveAlarm : next scheduled alarm time
  }
}

ActiveAlarm --> Off : no active alarms
Ringing --> Ringing : user sets an activated alarm
StoppedByUser --> Ringing : user turns off activated alarm
@enduml
