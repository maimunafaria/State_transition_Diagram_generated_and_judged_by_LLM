@startuml
title Alarm Clock State Diagram

state Off {
  [*] --> Off
}

state ActiveAlarm {
  state Ringing {
    Off --> Ringing : user sets an alarm time
    Ringing --> StartRinging : current time matches set alarm time
    Ringing --> StoppedByUser : user stops alarm
    Ringing --> NextScheduledAlarm : time passes
  }

  state Stopped {
    [*] --> Stopped : user turns off activated alarm
    Stopped --> ActiveAlarm : next scheduled alarm time
  }
}

ActiveAlarm --> Off : no active alarms
Ringing --> Ringing : no event (no action when ringing)
Stopped --> Stopped : no event (no action when stopped)
@enduml
