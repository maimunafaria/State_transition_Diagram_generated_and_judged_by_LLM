@startuml
title Online Quiz System State Diagram

[*] --> Start

state Start
state "LoggedIn" as LoggedIn
state "TeacherMenu" as TeacherMenu
state "StudentMenu" as StudentMenu
state "CreatingQuiz" as CreatingQuiz
state "EditingQuiz" as EditingQuiz
state "ViewingQuizResults" as ViewingResults
state "SelectingQuiz" as SelectingQuiz
state "AnsweringQuiz" as AnsweringQuiz
