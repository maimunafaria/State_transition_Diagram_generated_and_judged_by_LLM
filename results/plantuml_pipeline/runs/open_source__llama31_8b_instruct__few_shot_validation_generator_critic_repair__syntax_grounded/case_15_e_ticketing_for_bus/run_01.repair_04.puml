@startuml
title E Ticketing For Bus - State Diagram

[*] --> CreateUser

state "Create User" as CreateUser
state "Validate User" as ValidateUser
state "Login" as Login
state "Check Ticket Status" as CheckTicketStatus
state "Book Ticket" as BookTicket
state "Manage Account" as ManageAccount
state "Logout" as Logout

CreateUser --> ValidateUser : Registration Successful
ValidateUser --> Login : Login Successful

Login --> CheckTicketStatus : Ticket Status Checked
CheckTicketStatus --> Login : Return to Login

Login --> BookTicket : Book Ticket
BookTicket --> Login : Payment Successful

Login --> ManageAccount : Manage Account
ManageAccount --> Login : Return to Login

Login --> Logout : Logout Successful

Logout --> [*] : Logout Completed

CreateUser --> Login : Create User
ValidateUser --> Login : Validate User
BookTicket --> CheckTicketStatus : Book Ticket
CheckTicketStatus --> ManageAccount : Check Ticket Status
ManageAccount --> Logout : Manage Account
Logout --> CreateUser : Logout

@enduml
